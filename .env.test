# Aftertalk Core Configuration
# Copy this file to .env and configure your values

# Database
DATABASE_PATH=./aftertalk.db

# HTTP Server
HTTP_PORT=8080
HTTP_HOST=0.0.0.0

# WebSocket Server
WS_PORT=8081
WS_HOST=0.0.0.0

# Logging
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json  # json, console

# JWT Configuration
JWT_SECRET=dev-secret-key-12345-change-this
JWT_ISSUER=aftertalk
JWT_EXPIRATION=2h

# API Key for backend authentication
API_KEY=dev-api-key-12345

# STT Provider Configuration
STT_PROVIDER=google  # google, aws, azure
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=your-azure-region

# LLM Provider Configuration
LLM_PROVIDER=openai  # openai, anthropic, azure
OPENAI_API_KEY=dev-api-key-12345
OPENAI_MODEL=gpt-4
ANTHROPIC_API_KEY=dev-api-key-12345
ANTHROPIC_MODEL=claude-3-opus-20240229
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Webhook Configuration
WEBHOOK_URL=https://your-backend.com/webhook/minutes
WEBHOOK_TIMEOUT=30s

# Processing Configuration
MAX_CONCURRENT_TRANSCRIPTIONS=10
MAX_CONCURRENT_MINUTES_GENERATIONS=5
TRANSCRIPTION_TIMEOUT=10m
MINUTES_GENERATION_TIMEOUT=5m

# Session Configuration
MAX_SESSION_DURATION=2h
MAX_PARTICIPANTS_PER_SESSION=10

# Retention Configuration (days)
TRANSCRIPTION_RETENTION_DAYS=90
MINUTES_RETENTION_DAYS=90
WEBHOOK_EVENTS_RETENTION_DAYS=30

# Performance
ENABLE_PROFILING=false
PROFILING_PORT=6060
