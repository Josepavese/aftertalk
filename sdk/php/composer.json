{
  "name": "aftertalk/aftertalk-php",
  "description": "PHP SDK for the Aftertalk REST API — session management, participant tokens, webhook verification.",
  "type": "library",
  "license": "MIT",
  "keywords": ["aftertalk", "sdk", "webhook", "webrtc", "transcription", "minutes"],
  "homepage": "https://github.com/Josepavese/aftertalk",
  "require": {
    "php": ">=8.1",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.1",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "guzzlehttp/guzzle": "^7.0",
    "php-http/mock-client": "^1.5"
  },
  "suggest": {
    "guzzlehttp/guzzle": "Default HTTP client (^7.0)",
    "symfony/http-client": "Alternative PSR-18 HTTP client"
  },
  "autoload": {
    "psr-4": {
      "Aftertalk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Aftertalk\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit tests/"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
