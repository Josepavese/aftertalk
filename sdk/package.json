{
  "name": "@aftertalk/sdk",
  "version": "1.0.0",
  "description": "Aftertalk JavaScript/TypeScript SDK for WebRTC audio transcription",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
